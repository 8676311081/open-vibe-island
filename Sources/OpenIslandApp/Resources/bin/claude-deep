#!/bin/zsh
# Claude Code routed through Open Island's DeepSeek-only listener
# (port 9711, ProviderGroup.deepseek). The 9711 listener admits
# only profiles whose id is `deepseek-v4-pro` / `deepseek-v4-flash`
# (the builtin DeepSeek profiles). Anything else gets 421 from
# the listener — `claude-deep` is intentionally narrower than
# `claude-3`, which auto-picks the port for whatever group the
# GUI-active profile belongs to.
#
# Usage:
#   claude-deep [args...]
#       Connects to 9711. The proxy serves the GUI-active profile
#       iff it's a DeepSeek builtin; otherwise replies 421 with
#       a structured "active profile is in <group>, switch via
#       Settings → Model Routing or use claude-3" body.
#   OI_PROFILE=<id> claude-deep [args...]
#       Per-invocation profile override. The 9711 listener still
#       enforces group: pass a deepseek-* builtin id, otherwise
#       you'll get 421 (use claude-3 with OI_PROFILE for cross-
#       group overrides).
#
# Environment:
#   OPEN_ISLAND_PORT          Override the loopback port. Defaults
#                             to 9711 (the DeepSeek listener).
#   OI_PROFILE                Per-invocation profile override id.
#
# Exported to children:
#   OPEN_ISLAND_PROVIDER_GROUP=deepseek
#                             Always set on this shim. PreToolUse
#                             hooks (RTK, etc.) attribute work
#                             via this env.
#
# Pairs with:
#   claude         — official binary, OAuth direct connect (do not
#                    touch — Anthropic Max/Pro client identity check
#                    fails through any proxy).
#   claude-3       — proxy routing that auto-picks the port matching
#                    the GUI-active profile's group.
#   claude-native  — explicitly bypass the proxy for ambient OAuth.

: "${OPEN_ISLAND_PORT:=9711}"

if [ -n "${OI_PROFILE:-}" ]; then
    base="http://127.0.0.1:${OPEN_ISLAND_PORT}/_oi/profile/${OI_PROFILE}"
else
    # No more `_oi/family/deepseek` sentinel — the listener IS the
    # DeepSeek family now. Plain base URL is enough.
    base="http://127.0.0.1:${OPEN_ISLAND_PORT}"
fi

exec env \
    ANTHROPIC_BASE_URL="${base}" \
    OPEN_ISLAND_PROVIDER_GROUP="deepseek" \
    claude "$@"
